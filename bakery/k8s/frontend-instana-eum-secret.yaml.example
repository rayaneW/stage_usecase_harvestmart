---
# EXAMPLE FILE ONLY - DO NOT COMMIT REAL VALUES
# 1. Copy this file to frontend-instana-eum-secret.yaml
# 2. Replace the placeholder key with your real Instana EUM key
# 3. Apply locally: kubectl apply -f bakery/k8s/frontend-instana-eum-secret.yaml

apiVersion: v1
kind: Secret
metadata:
  name: frontend-instana-eum
  namespace: freshmart
type: Opaque
stringData:
  INSTANA_EUM_KEY: REPLACE_WITH_REAL_INSTANA_EUM_KEY
