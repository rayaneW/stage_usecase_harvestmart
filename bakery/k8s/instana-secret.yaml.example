---
# EXAMPLE FILE ONLY - DO NOT COMMIT REAL CREDENTIALS
# This file shows the structure for Instana agent secrets
# Replace placeholder values with real credentials from your Instana account
#
# Instructions:
# 1. Copy this file to instana-secret.yaml (without .example)
# 2. Replace the placeholder base64 values with real credentials:
#    - INSTANA_AGENT_KEY: Your Instana agent key (base64 encoded)
#    - INSTANA_AGENT_DOWNLOAD_KEY: Your download key (base64 encoded)
# 3. Add instana-secret.yaml to .gitignore
# 4. Deploy locally with: kubectl apply -f instana-secret.yaml
#
# To encode a value: echo -n "your-value" | base64
# To decode: echo "base64-value" | base64 -d

apiVersion: v1
kind: Secret
metadata:
  name: instana-agent
  namespace: instana-agent
  labels:
    app.kubernetes.io/name: instana-agent
    app.kubernetes.io/version: 1.2.74
type: Opaque
data:
  key: REPLACE_WITH_YOUR_AGENT_KEY_BASE64
  downloadKey: REPLACE_WITH_YOUR_DOWNLOAD_KEY_BASE64
